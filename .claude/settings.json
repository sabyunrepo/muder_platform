{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && touch graphify-out/.needs_update 2>/dev/null; true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "harness@harness-marketplace": true,
    "compound-mmp@ctm": true
  },
  "extraKnownMarketplaces": {
    "ctm": {
      "source": {
        "source": "directory",
        "path": ".claude/plugins"
      }
    }
  }
}
