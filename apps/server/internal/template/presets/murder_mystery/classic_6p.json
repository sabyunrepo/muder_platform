{
  "id": "murder_mystery_classic_6p",
  "genre": "murder_mystery",
  "name": "Classic Murder Mystery (6P)",
  "description": "Traditional 6-player murder mystery with 4 rounds of clue distribution and voting",
  "version": "1.0.0",
  "modules": [
    {"id": "connection"},
    {"id": "room"},
    {"id": "ready", "config": {"totalPlayers": 6}},
    {"id": "text_chat", "config": {"maxLength": 300}},
    {"id": "starting_clue"},
    {"id": "round_clue", "config": {"totalRounds": 4}},
    {"id": "voting", "config": {"mode": "open", "minParticipation": 75, "tieBreaker": "revote", "maxRounds": 2}},
    {"id": "accusation", "config": {"maxPerRound": 1, "defenseTime": 60, "voteThreshold": 50}},
    {"id": "ending", "config": {"RevealSteps": ["culprit", "timeline", "relationships"]}},
    {"id": "audio"}
  ],
  "phases": [
    {"id": "lobby", "name": "Lobby"},
    {"id": "intro", "name": "Introduction", "duration": 300},
    {"id": "round_1", "name": "Round 1 - Investigation", "duration": 600, "actions": [{"action": "UNMUTE_CHAT", "target": "text_chat"}]},
    {"id": "discuss_1", "name": "Round 1 - Discussion", "duration": 480},
    {"id": "round_2", "name": "Round 2 - Investigation", "duration": 600},
    {"id": "discuss_2", "name": "Round 2 - Discussion", "duration": 480},
    {"id": "round_3", "name": "Round 3 - Investigation", "duration": 600},
    {"id": "discuss_3", "name": "Round 3 - Discussion", "duration": 480},
    {"id": "round_4", "name": "Final Round", "duration": 600},
    {"id": "final_vote", "name": "Final Vote", "duration": 300, "actions": [{"action": "OPEN_VOTING", "target": "voting"}]},
    {"id": "ending", "name": "Reveal"}
  ]
}
