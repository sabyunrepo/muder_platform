    "@tanstack/react-query": "^5.96.2",
    "@xyflow/react": "^12.10.2",
    "dompurify": "^3.3.3",
    "livekit-client": "^2.18.1",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-error-boundary": "^6.1.1",
