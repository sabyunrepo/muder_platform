{
  "id": "murder_mystery_expert_8p",
  "genre": "murder_mystery",
  "name": "Expert Murder Mystery (8P)",
  "description": "Advanced 8-player murder mystery with hidden missions, conditional clues, and secret voting",
  "version": "1.0.0",
  "modules": [
    {"id": "connection"},
    {"id": "room"},
    {"id": "ready", "config": {"totalPlayers": 8}},
    {"id": "text_chat", "config": {"maxLength": 300}},
    {"id": "whisper"},
    {"id": "starting_clue"},
    {"id": "round_clue", "config": {"totalRounds": 5}},
    {"id": "conditional_clue"},
    {"id": "voting", "config": {"mode": "secret", "minParticipation": 75, "tieBreaker": "revote", "maxRounds": 3}},
    {"id": "accusation", "config": {"maxPerRound": 2, "defenseTime": 90, "voteThreshold": 60}},
    {"id": "hidden_mission"},
    {"id": "ending", "config": {"RevealSteps": ["culprit", "timeline", "relationships", "mission_scores"]}},
    {"id": "audio"}
  ],
  "phases": [
    {"id": "lobby", "name": "Lobby"},
    {"id": "intro", "name": "Introduction", "duration": 600},
    {"id": "round_1", "name": "Round 1", "duration": 720, "actions": [{"action": "UNMUTE_CHAT", "target": "text_chat"}]},
    {"id": "discuss_1", "name": "Discussion 1", "duration": 600},
    {"id": "round_2", "name": "Round 2", "duration": 720},
    {"id": "discuss_2", "name": "Discussion 2", "duration": 600},
    {"id": "round_3", "name": "Round 3", "duration": 720},
    {"id": "discuss_3", "name": "Discussion 3", "duration": 600},
    {"id": "round_4", "name": "Round 4", "duration": 720},
    {"id": "discuss_4", "name": "Discussion 4", "duration": 600},
    {"id": "round_5", "name": "Final Round", "duration": 720},
    {"id": "final_vote", "name": "Final Vote", "duration": 420, "actions": [{"action": "OPEN_VOTING", "target": "voting"}]},
    {"id": "ending", "name": "Reveal"}
  ]
}
