{
  "id": "murder_mystery_quick_4p",
  "genre": "murder_mystery",
  "name": "Quick Murder Mystery (4P)",
  "description": "Fast-paced 4-player murder mystery with 2 rounds, ideal for casual play",
  "version": "1.0.0",
  "modules": [
    {"id": "connection"},
    {"id": "room"},
    {"id": "ready", "config": {"totalPlayers": 4}},
    {"id": "text_chat", "config": {"maxLength": 200}},
    {"id": "starting_clue"},
    {"id": "round_clue", "config": {"totalRounds": 2}},
    {"id": "voting", "config": {"mode": "open", "minParticipation": 100, "tieBreaker": "random", "maxRounds": 1}},
    {"id": "ending", "config": {"RevealSteps": ["culprit"]}},
    {"id": "audio"}
  ],
  "phases": [
    {"id": "lobby", "name": "Lobby"},
    {"id": "intro", "name": "Introduction", "duration": 180},
    {"id": "round_1", "name": "Round 1", "duration": 420, "actions": [{"action": "UNMUTE_CHAT", "target": "text_chat"}]},
    {"id": "discuss_1", "name": "Discussion", "duration": 300},
    {"id": "round_2", "name": "Final Round", "duration": 420},
    {"id": "final_vote", "name": "Vote", "duration": 180, "actions": [{"action": "OPEN_VOTING", "target": "voting"}]},
    {"id": "ending", "name": "Reveal"}
  ]
}
