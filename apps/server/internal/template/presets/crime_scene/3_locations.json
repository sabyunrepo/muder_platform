{
  "id": "crime_scene_3loc",
  "genre": "crime_scene",
  "name": "Crime Scene Investigation (3 Locations)",
  "description": "Investigate 3 crime scene locations to find evidence and identify the culprit",
  "version": "1.0.0",
  "modules": [
    {"id": "connection"},
    {"id": "room"},
    {"id": "ready", "config": {"totalPlayers": 5}},
    {"id": "text_chat"},
    {"id": "location_clue", "config": {"showClueCount": true, "allowRepeatSearch": false}},
    {"id": "floor_exploration", "config": {"allowChangeFloor": true, "showOccupancy": true}},
    {"id": "clue_interaction", "config": {"drawLimit": 3, "duplicatePolicy": "exclusive"}},
    {"id": "accusation", "config": {"maxPerRound": 1, "defenseTime": 90, "voteThreshold": 60}},
    {"id": "ending", "config": {"RevealSteps": ["culprit", "timeline"]}},
    {"id": "audio"}
  ],
  "phases": [
    {"id": "lobby", "name": "Lobby"},
    {"id": "briefing", "name": "Case Briefing", "duration": 300},
    {"id": "investigate_1", "name": "Investigation Phase 1", "duration": 600, "actions": [{"action": "UNMUTE_CHAT", "target": "text_chat"}]},
    {"id": "debrief_1", "name": "Team Debrief 1", "duration": 300},
    {"id": "investigate_2", "name": "Investigation Phase 2", "duration": 600},
    {"id": "debrief_2", "name": "Team Debrief 2", "duration": 300},
    {"id": "accusation", "name": "Final Accusation", "duration": 300},
    {"id": "ending", "name": "Case Closed"}
  ]
}
